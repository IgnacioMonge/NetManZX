 471+ 8A4E              ; compareStringZ - Compara dos strings Z-terminated
 472+ 8A4E              ; Entrada: HL, DE = punteros a strings
 473+ 8A4E              ; Salida:  Z=1 si iguales, Z=0 si diferentes
 474+ 8A4E              ;          CF=0 siempre
 475+ 8A4E              ; Destruye: A, BC
 476+ 8A4E              ; ============================================
 477+ 8A4E              compareStringZ:
 478+ 8A4E              .loop
 479+ 8A4E 1A               ld a, (de)
 480+ 8A4F 4F               ld c, a
 481+ 8A50 7E               ld a, (hl)
 482+ 8A51 B9               cp c
 483+ 8A52 C0               ret nz              ; Diferentes -> Z=0
 484+ 8A53 A7               and a
 485+ 8A54 C8               ret z               ; Ambos 0 -> iguales, Z=1
 486+ 8A55 23               inc hl
 487+ 8A56 13               inc de
 488+ 8A57 18 F5            jr .loop
