   1+ B399                  module Uart
   2+ B399
   3+ B399              ; Timeout por defecto - Next necesita más porque su CPU es más rápida
   4+ B399                  IFDEF NEXT
   5+ B399 ~            DEFAULT_TIMEOUT = #FFFF          ; Next: timeout máximo 16-bit
   6+ B399                  ELSE
   7+ B399              DEFAULT_TIMEOUT = #8000          ; UNO/divMMC: (~1.6s a 3.5MHz)
   8+ B399                  ENDIF
   9+ B399
  10+ B399              ; Timeout largo: se implementa como varios bloques para tolerar pausas
  11+ B399              ; largas (JOIN/DHCP/SCAN) sin declarar timeout prematuro.
  12+ B399              ; Next tiene CPU más rápida, necesita más repeticiones
  13+ B399              LONG_TIMEOUT_BLOCK = #FFFF
