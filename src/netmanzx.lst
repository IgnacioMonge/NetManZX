   1+ 92A6                  ; Generate VERSION_STRING from define V
   2+ 92A6                  ; V = Mmp...  (M=major digit, m=minor digit, p=patch digits optional)
   3+ 92A6                  ; Examples: V=12  -> "1.2"
   4+ 92A6                  ;           V=121 -> "1.2.1"
   5+ 92A6                  ;           V=1210 -> "1.2.10"
   6+ 92A6                  LUA ALLPASS
   7+ 92A6 ~                v = tostring(sj.get_define("V"))
   8+ 92A6 ~                maj = string.sub(v, 1, 1)
   9+ 92A6 ~                min = string.sub(v, 2, 2)
  10+ 92A6 ~                patch = string.sub(v, 3)
  11+ 92A6 ~
  12+ 92A6 ~                ver = maj .. "." .. min
  13+ 92A6 ~                if patch ~= nil and patch ~= "" then
  14+ 92A6 ~                    ver = ver .. "." .. patch
  15+ 92A6 ~                end
  16+ 92A6 ~
  17+ 92A6 ~                sj.insert_define("VERSION_STRING", "\"" .. ver .. "\"")
  18+ 92A6                  ENDLUA
