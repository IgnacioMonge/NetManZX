3850+ AF93              ; ============================================
3851+ AF93              ; checkAsyncWifi - Detecta eventos WiFi asíncronos
3852+ AF93              ; Busca "DISCONNECT" y "GOT IP" en el stream UART
3853+ AF93              ; Retorna: A = código de evento
3854+ AF93              ;   ASYNC_EVENT_NONE (0) = sin evento
3855+ AF93              ;   ASYNC_EVENT_DISCONNECT (1) = desconexión detectada
3856+ AF93              ;   ASYNC_EVENT_GOTIP (2) = conexión detectada
3857+ AF93              ; ============================================
3858+ AF93              ASYNC_EVENT_NONE       = 0
3859+ AF93              ASYNC_EVENT_DISCONNECT = 1
3860+ AF93              ASYNC_EVENT_GOTIP      = 2
3861+ AF93
3862+ AF93              checkAsyncWifi:
3863+ AF93                  ; NO leer UART si hay operación crítica en curso
3864+ AF93 3A 5F 92         ld a, (Wifi.uart_busy)
3865+ AF96 A7               and a
3866+ AF97 28 02            jr z, .canRead
3867+ AF99 AF               xor a                       ; A = ASYNC_EVENT_NONE
3868+ AF9A C9               ret
3869+ AF9B
3870+ AF9B              .canRead
3871+ AF9B                  ; Intentar leer un byte del UART (no bloqueante)
3872+ AF9B CD B8 BE         call UartImpl.uartRead
3873+ AF9E 38 02            jr c, .gotByte
3874+ AFA0 AF               xor a                       ; A = ASYNC_EVENT_NONE
3875+ AFA1 C9               ret
3876+ AFA2
3877+ AFA2              .gotByte
3878+ AFA2                  ; A = byte leído
3879+ AFA2                  ; Ignorar caracteres de control (CR, LF, etc)
3880+ AFA2 FE 20            cp 32
