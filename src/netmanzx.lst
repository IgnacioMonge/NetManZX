  29+ B538 7E               ld a, (hl)
  30+ B539 A7               and a
  31+ B53A C8               ret z               ; Sin tecla, devolver 0
  32+ B53B 36 00            ld (hl), 0          ; Limpiar inmediatamente
  33+ B53D C9               ret
  34+ B53E
  35+ B53E                  endmodule
