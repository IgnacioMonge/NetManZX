  13+ B526 C0               ret nz                  ; No pulsado, Z=0
  14+ B527 3E FE            ld a, #FE               ; Fila CAPS SHIFT (SHIFT-V)
  15+ B529 DB FE            in a, (#FE)
  16+ B52B CB 47            bit 0, a                ; CAPS SHIFT es bit 0
  17+ B52D C9               ret                     ; Z=1 si ambos pulsados
  18+ B52E
  19+ B52E              ; Lectura bloqueante - espera hasta que haya tecla
